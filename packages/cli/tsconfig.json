{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": true,
    "types": ["node"]
  },
  "references": [
    { "path": "../@agent-gateway/core" },
    { "path": "../@agent-gateway/node" }
  ],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}