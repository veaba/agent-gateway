{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "agent-gateway",
  "version": "0.1.0",
  "identifier": "com.agent-gateway.app",
  "build": {
    "beforeDevCommand": "cd ../web && npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "cd ../web && npm run build",
    "frontendDist": "../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Agent Gateway",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
"bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}